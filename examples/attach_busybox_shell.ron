(
    // This demo is meant for `mantissa tasks attach`.
    // Use Ctrl-P, Ctrl-Q to detach and leave the task running.
    // Ctrl-] also detaches locally if the default sequence is swallowed by the terminal.
    // Typing `exit` exits the shell entrypoint itself, so the task stops and is later
    // reconciled back by the service controller, matching `docker attach` semantics.
    name: "attach-shell-demo",
    tasks: [
        (
            name: "shell",
            image: "busybox:1.36",
            command: [
                "sh",
                "-i",
            ],
            replicas: 3,
            resources: (
                cpu_millis: 100,
                memory_mb: 32,
            ),
            tty: true,
            env: [],
            secret_files: [],
            networks: [],
        ),
    ],
)
