(
    name: "rolling-demo",
    update: (
        mode: rolling,
        rolling: (
            parallelism: 2,
            order: start_first,
            startup_timeout_secs: 600,
            monitor_secs: 15,
            max_failures: 2,
            auto_rollback: true,
        ),
    ),
    tasks: [
        (
            name: "api",
            image: "hashicorp/http-echo:1.0.0",
            command: [
                "-listen",
                ":8000",
                "-text",
                "hello from backend replica",
            ],
            replicas: 4,
            resources: (
                cpu_millis: 300,
                memory_mb: 256,
            ),
            env: [],
            secret_files: [],
            health_port: Some(8000),
            health_command: Some([
                "/",
            ]),
        ),
    ],
)
