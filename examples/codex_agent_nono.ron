(
    name: "codex-agent-nono",
    execution_platform: "oci",
    isolation_mode: "sandboxed",
    isolation_profile: Some("nono-default"),
    volumes: [
        (
            name: "workspace",
            driver: local((
                source: managed,
            )),
            access_mode: read_write_once,
            binding_mode: wait_for_first_consumer,
            reclaim_policy: retain,
            capacity_mb: Some(1024),
        ),
    ],
    execution: (
        image: "node:22-bookworm-slim",
        command: [
            "sh",
            "-lc",
            "mkdir -p \"$MANTISSA_AGENT_WORKDIR\" \"$HOME\" \"$XDG_CONFIG_HOME\" \"$XDG_CACHE_HOME\" \"$XDG_STATE_HOME\" \"$NPM_CONFIG_CACHE\" && exec npx -y @openai/codex exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox -C \"$MANTISSA_AGENT_WORKDIR\" \"$MANTISSA_AGENT_INPUT\"",
        ],
        resources: (
            cpu_millis: 1000,
            memory_mb: 1024,
        ),
        termination_grace_period_secs: Some(30),
        env: [
            (
                name: "OPENAI_API_KEY",
                value: None,
                secret: Some((
                    name: "openai-api-key",
                    version: None,
                )),
            ),
            (
                name: "HOME",
                value: Some("/workspace/.home"),
                secret: None,
            ),
            (
                name: "XDG_CONFIG_HOME",
                value: Some("/workspace/.config"),
                secret: None,
            ),
            (
                name: "XDG_CACHE_HOME",
                value: Some("/workspace/.cache"),
                secret: None,
            ),
            (
                name: "XDG_STATE_HOME",
                value: Some("/workspace/.local/state"),
                secret: None,
            ),
            (
                name: "NPM_CONFIG_CACHE",
                value: Some("/workspace/.npm"),
                secret: None,
            ),
        ],
    ),
    workspace: (
        mount: Some((
            source: "workspace",
            target: "/workspace",
            read_only: false,
        )),
        working_directory: Some("/workspace"),
        persistent: true,
    ),
    tools: (
        allowed_tools: ["shell"],
        allow_network: true,
        allow_pty: false,
        allow_write: true,
    ),
    interaction: (
        require_user_input_between_runs: true,
        max_turns_per_run: 1,
    ),
    pending_input: Some("Inside the workspace, create a file named hello.txt containing a one-line greeting from Codex running inside a Mantissa nono sandbox, then print the file contents."),
)
